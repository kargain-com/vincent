# Founder-run epoch publish (never commit real values)

# --- Testnet: publish:epoch -- --network base-sepolia (alias: --devnet) ---

# EVM private key for signing manifests and paying Irys devnet + Base Sepolia gas
VINCENT_GENESIS_PRIVATE_KEY=

# Base Sepolia JSON-RPC (anchor registry + Irys base-eth uploads on devnet.irys.xyz)
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# Optional Irys read endpoints (defaults shown; --devnet CLI uses testnet gateway when unset)
IRYS_GATEWAY_URL=https://gateway.irys.xyz
# IRYS_GATEWAY_URL=https://testnet-gateway.irys.xyz
IRYS_GRAPHQL_URL=https://uploader.irys.xyz/graphql

# Optional: recover a confirmed Base Sepolia Irys fund tx that failed bundler registration
# VINCENT_IRYS_RECOVER_FUND_TX=0x...

# Devnet is for validation only. Mainnet genesis is a separate later step.
# Never commit .env or private keys to the repository.

# --- Base mainnet (8453): publish:epoch -- --network base (alias: --mainnet) ---
# Requires registry deploy on 8453 (P2). Re-upload is off by default; use --allow-reupload.
#
# BASE_MAINNET_RPC_URL=https://mainnet.base.org
# VINCENT_GENESIS_PRIVATE_KEY=
# IRYS_GATEWAY_URL=https://gateway.irys.xyz
# IRYS_GRAPHQL_URL=https://uploader.irys.xyz/graphql
# Registry CREATE2 (same address on every EVM chain): 0x06667DB3795C70F34b7517D1Af1217D3167BE241
# Chain ID: 8453 (BASE_MAINNET_CHAIN_ID)
# Irys bundler: https://node2.irys.xyz (IRYS_MAINNET_BUNDLER_URL)
