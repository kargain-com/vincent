# Founder-run genesis publish (never commit real values)

# EVM private key for signing manifests and paying Irys devnet + Base Sepolia gas
VINCENT_GENESIS_PRIVATE_KEY=

# Base Sepolia JSON-RPC endpoint (for VincentAnchorRegistry publishEpoch gas)
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# Ethereum Sepolia JSON-RPC for Irys Ethereum devnet uploads (NOT an Irys gateway URL)
IRYS_SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com

# Optional Irys read endpoints (defaults shown)
IRYS_GATEWAY_URL=https://gateway.irys.xyz
IRYS_GRAPHQL_URL=https://uploader.irys.xyz/graphql

# Devnet is for validation only. Mainnet genesis is a separate later step.
# Never commit .env or private keys to the repository.
