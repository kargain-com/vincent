{
  "name": "@kargain/vincent-publish",
  "version": "0.0.2",
  "private": true,
  "type": "module",
  "license": "MIT",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "pretest": "pnpm --filter @kargain/vincent-contracts build",
    "test": "vitest run --no-file-parallelism",
    "prevalidate:full-sim": "pnpm --filter @kargain/vincent-contracts build",
    "validate:full-sim": "node --max-old-space-size=8192 ./node_modules/vitest/vitest.mjs run --config vitest.full-sim.config.ts --no-file-parallelism",
    "publish:epoch": "pnpm run build && node dist/cli/publish-epoch.js",
    "publish:genesis": "pnpm run build && node dist/cli/publish-epoch.js --genesis",
    "publish:community": "pnpm run build && node dist/cli/publish-community.js",
    "backfill:leaf-uris": "pnpm run build && node dist/cli/backfill-leaf-uris.js",
    "export:leaf-uris": "pnpm run build && node dist/cli/export-leaf-uris.js",
    "publish:leaf-uris": "pnpm run build && node dist/cli/publish-leaf-uris.js"
  },
  "dependencies": {
    "@irys/upload": "^0.0.3",
    "@irys/upload-ethereum": "^0.0.3",
    "@kargain/vincent": "workspace:*",
    "@kargain/vincent-compiler": "workspace:*",
    "bignumber.js": "^9.1.2",
    "dotenv": "^16.4.7",
    "viem": "^2.31.0"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox-viem": "^5.0.7",
    "@types/node": "catalog:",
    "@vitest/coverage-v8": "4.1.10",
    "hardhat": "^3.9.1",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
