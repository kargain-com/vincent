{
  "name": "@kargain/vincent",
  "version": "0.7.0",
  "description": "Offline-first deterministic VIN validation, decoding, and WMI lookup per ISO 3779.",
  "keywords": [
    "vin",
    "vin-decoder",
    "vehicle",
    "iso-3779",
    "offline"
  ],
  "type": "module",
  "sideEffects": false,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kargain-com/vincent.git",
    "directory": "packages/vincent"
  },
  "homepage": "https://github.com/kargain-com/vincent#readme",
  "bugs": "https://github.com/kargain-com/vincent/issues",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=24"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./wmi": {
      "types": "./dist/wmi-export.d.ts",
      "import": "./dist/wmi-export.js"
    },
    "./protocol": {
      "types": "./dist/protocol/index.d.ts",
      "import": "./dist/protocol/index.js"
    },
    "./decoder": {
      "types": "./dist/decoder-export.d.ts",
      "import": "./dist/decoder-export.js"
    },
    "./arweave": {
      "types": "./dist/arweave-export.d.ts",
      "import": "./dist/arweave-export.js"
    },
    "./anchor": {
      "types": "./dist/anchor-export.d.ts",
      "import": "./dist/anchor-export.js"
    }
  },
  "peerDependencies": {
    "viem": "^2.31.0"
  },
  "peerDependenciesMeta": {
    "viem": {
      "optional": true
    }
  },
  "dependencies": {
    "@noble/curves": "^1.9.7",
    "@noble/hashes": "^1.8.0"
  },
  "scripts": {
    "build": "node -e \"fs.rmSync('dist',{recursive:true,force:true})\" && tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run --coverage"
  },
  "devDependencies": {
    "@kargain/vincent-compiler": "workspace:*",
    "@types/node": "catalog:",
    "@vitest/coverage-v8": "4.1.10",
    "typescript": "catalog:",
    "viem": "^2.31.0",
    "vitest": "catalog:"
  }
}
