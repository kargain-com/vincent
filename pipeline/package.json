  "dependencies": {
    "@kargain/vincent": "workspace:*",
    "@kargain/vincent-compiler": "workspace:*"
  },
  "devDependencies": {
    "@types/adm-zip": "catalog:",
    "@types/node": "catalog:",
    "adm-zip": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
